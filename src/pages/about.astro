---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Ricardo Quintero" description="Learn more about Ricardo Quintero, a Unity Developer specializing in C# gameplay programming.">
    <section class="px-6 sm:px-8 pt-16 pb-24 sm:pt-24">
        <div class="max-w-6xl mx-auto">
            <div class="section-heading fade-in">
                <h2>About <span class="text-primary">Me</span></h2>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
                <!-- Bio -->
                <div class="lg:col-span-3 fade-in fade-in-delay-1">
                    <div class="space-y-5 text-gray-300 leading-relaxed text-lg">
                        <p>
                            I am a <strong class="text-white">Unity Developer</strong> specializing in <strong class="text-white">C# gameplay programming</strong>. My focus is on building interactive experiences that feel engaging and responsive — from core mechanics and player systems to complete gameplay loops.
                        </p>
                        <p>
                            I have experience developing complete game systems, including player controllers, resource management, AI behaviors, and UI integration. I enjoy the process of turning ideas into playable experiences and solving the technical challenges that come with game development.
                        </p>
                        <p>
                            Beyond programming, I work with <strong class="text-white">Blender</strong> for 3D asset creation and prototyping. This allows me to handle both the technical and visual sides of a project — from modeling game-ready assets to building environments that support the gameplay experience.
                        </p>
                        <p>
                            I am passionate about interactive media and always looking to improve my craft, whether it is through learning new tools, optimizing existing systems, or exploring fresh ideas in game design.
                        </p>
                    </div>
                </div>

                <!-- Skills -->
                <div class="lg:col-span-2 fade-in fade-in-delay-2">
                    <div class="card">
                        <h3 class="text-xl font-bold mb-6">Skills & Tools</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">Unity Engine</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/15 text-primary">Advanced</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">C# Programming</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/15 text-primary">Advanced</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">Blender</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent/15 text-accent">Intermediate</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">Gameplay Systems</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/15 text-primary">Advanced</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">Game Design</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent/15 text-accent">Intermediate</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-300">Version Control (Git)</span>
                                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent/15 text-accent">Intermediate</span>
                            </div>
                        </div>
                    </div>
                    <div class="card mt-6">
                        <h3 class="text-xl font-bold mb-4">What I Work With</h3>
                        <div class="flex flex-wrap gap-2">
                            <span class="tag text-xs">Unity</span>
                            <span class="tag text-xs">C#</span>
                            <span class="tag text-xs">Blender</span>
                            <span class="tag text-xs">.NET</span>
                            <span class="tag text-xs">Visual Studio</span>
                            <span class="tag text-xs">Git</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

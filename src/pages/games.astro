---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Games | Ricardo Quintero" description="Game portfolio showcasing Unity projects by Ricardo Quintero.">
    <section class="px-6 sm:px-8 pt-16 pb-24 sm:pt-24">
        <div class="max-w-6xl mx-auto">
            <div class="section-heading fade-in">
                <h2>My <span class="text-primary">Games</span></h2>
                <p class="text-lg">Projects built with passion, code, and creativity.</p>
            </div>

            <!-- Games Grid: 1 col mobile, 2 col tablet, 2 col desktop -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">

                <!-- Cash & Metal -->
                <article class="game-card fade-in fade-in-delay-1">
                    <div class="game-card-image-wrapper">
                        <div class="game-card-image-circle">
                            <img
                                src="/images/cash-metal-logo.png"
                                alt="Cash &amp; Metal logo"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    </div>
                    <div class="game-card-content">
                        <h3 class="text-xl font-bold mb-2">Cash &amp; Metal</h3>
                        <p class="text-text-muted text-sm leading-relaxed mb-3">
                            A fast-paced combat arena game inspired by the intensity and destructive chaos of BattleBots. Take control of a metal-clad robot and battle enemy machines in a brutal arena where survival is the only objective.
                        </p>
                        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">
                            Full Game Developer
                        </p>
                        <a href="https://rickquintero.itch.io/crash-metal" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm w-full">
                            Play / View Project
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                            </svg>
                        </a>
                    </div>
                </article>

                <!-- Hunger of the Forest -->
                <article class="game-card fade-in fade-in-delay-2">
                    <div class="game-card-image-wrapper">
                        <div class="game-card-image-circle">
                            <img
                                src="/images/ui-icon-hunger-of-the-forest.png"
                                alt="Hunger of the Forest icon"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    </div>
                    <div class="game-card-content">
                        <h3 class="text-xl font-bold mb-2">Hunger of the Forest</h3>
                        <p class="text-text-muted text-sm leading-relaxed mb-3">
                            An orthographic top-down stylized survival game. Gather resources, craft tools, and survive the dangers lurking within the forest.
                        </p>
                        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">
                            Full Game Developer
                        </p>
                        <a href="https://rickquintero.itch.io/hunger-of-the-forest" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm w-full">
                            Play / View Project
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                            </svg>
                        </a>
                    </div>
                </article>

                <!-- The Beacon -->
                <article class="game-card fade-in fade-in-delay-3">
                    <div class="game-card-image-wrapper">
                        <div class="game-card-image-circle">
                            <img
                                src="/images/the-beacon-logo.png"
                                alt="The Beacon logo"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    </div>
                    <div class="game-card-content">
                        <h3 class="text-xl font-bold mb-2">The Beacon</h3>
                        <p class="text-text-muted text-sm leading-relaxed mb-3">
                            A game about living the quiet but vital duty of a lighthouse keeper. Keep the light alive and guide ships safely through the darkness. Explore by day to gather fuel and repair materials, then manage the lighthouse systems at night.
                        </p>
                        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">
                            Full Game Developer
                        </p>
                        <a href="https://rickquintero.itch.io/the-beacon" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm w-full">
                            Play / View Project
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                            </svg>
                        </a>
                    </div>
                </article>

                <!-- Final Charge -->
                <article class="game-card fade-in fade-in-delay-4">
                    <div class="game-card-image-wrapper">
                        <div class="game-card-image-circle">
                            <img
                                src="/images/final-charge-cover.jpg"
                                alt="Final Charge cover"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    </div>
                    <div class="game-card-content">
                        <h3 class="text-xl font-bold mb-2">Final Charge</h3>
                        <p class="text-text-muted text-sm leading-relaxed mb-3">
                            A 2.5D platformer where you play as Robot&iacute;n, a small robot escaping a factory about to be destroyed. With your battery almost empty, dodge obstacles and rebel robots before running out of power.
                        </p>
                        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-4">
                            Project Manager / Programmer
                        </p>
                        <a href="https://rickquintero.itch.io/final-charge" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm w-full">
                            Play / View Project
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                            </svg>
                        </a>
                    </div>
                </article>

            </div>
        </div>
    </section>
</Layout>

<style>
    .game-card {
        background: rgba(22, 33, 62, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        backdrop-filter: blur(8px);
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .game-card:hover {
        transform: translateY(-4px);
        border-color: rgba(108, 99, 255, 0.3);
        box-shadow: 0 10px 25px -5px rgba(108, 99, 255, 0.08),
                    0 8px 10px -6px rgba(108, 99, 255, 0.04);
    }

    .game-card-image-wrapper {
        width: 100%;
        padding: 2rem 2rem 0;
        display: flex;
        justify-content: center;
    }

    .game-card-image-circle {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid rgba(108, 99, 255, 0.3);
        background: rgba(26, 26, 46, 0.6);
        flex-shrink: 0;
    }

    .game-card-content {
        padding: 1.25rem 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
        width: 100%;
    }

    .game-card-content p.text-text-muted {
        flex: 1;
    }

    .btn-sm {
        --btn-py: 0.625rem;
        --btn-px: 1.25rem;
        --btn-font-size: 0.8125rem;
    }
</style>
